# -----------------------------------------------------------------------------
# SmartMeye Life DVR bridge configuration template
# -----------------------------------------------------------------------------
# 1) Copy this file to docker/.env
# 2) Fill credentials and IP
# 3) Keep defaults unless you need a specific override
#
# Mapping priority (important):
# - DVR_CHANNEL_MAP (if set) has priority over DVR_PROTOCOL_OFFSET
# - DVR_PROTOCOL_OFFSET is used only when DVR_CHANNEL_MAP is empty
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# DVR connection and authentication
# -----------------------------------------------------------------------------
# DVR LAN IP or hostname
DVR_IP=192.168.1.10
# DVR username
DVR_USER=changeme
# DVR password
DVR_PASSWORD=changeme

# -----------------------------------------------------------------------------
# DVR ports (SmartMeye/Life DVRIP defaults)
# -----------------------------------------------------------------------------
# Command/control socket
DVR_CMD_PORT=6001
# Media socket
DVR_DATA_PORT=6002

# -----------------------------------------------------------------------------
# Stream profile and stability
# -----------------------------------------------------------------------------
# Stream profile for the whole hub session:
# 0 = main stream, 1 = sub stream
DVR_STREAM=0
# Keepalive interval sent to DVR while streaming
DVR_KEEPALIVE=1s
# Delay before reconnect attempt after disconnect/error
DVR_RECONNECT=3s

# -----------------------------------------------------------------------------
# Logging and diagnostics
# -----------------------------------------------------------------------------
# Verbose human-readable logs: 0=off, 1=on
DVR_VERBOSE=0
# JSON logs: 0=off, 1=on
DVR_LOG_JSON=0
# Optional diagnostic packet log file
#DVR_DIAG_FILE=/config/diag_cam1.log

# -----------------------------------------------------------------------------
# Channel mapping (user channel -> protocol channel)
# -----------------------------------------------------------------------------
# Default formula: protocol = user + DVR_PROTOCOL_OFFSET
# Typical legacy mapping: cam1->0, cam2->1, cam3->2, ...
DVR_PROTOCOL_OFFSET=-1
# Optional explicit per-channel map (overrides offset), example:
#DVR_CHANNEL_MAP=1:0,2:1,3:2,4:3,5:4

# -----------------------------------------------------------------------------
# Metrics (optional)
# -----------------------------------------------------------------------------
# Prometheus endpoint bind address, example:
#DVR_METRICS_ADDR=127.0.0.1:9910

# -----------------------------------------------------------------------------
# Hub mode (single DVR session + local per-channel subscribers)
# -----------------------------------------------------------------------------
# Local bind for subscriber sockets (keep localhost unless needed)
DVR_HUB_BIND=127.0.0.1
# Subscriber port base; channel N listens on (base + N)
DVR_HUB_PORT_BASE=9100
# Enabled user channels (DVR supports up to 8 channels)
DVR_HUB_CHANNELS=1,2,3,4,5
