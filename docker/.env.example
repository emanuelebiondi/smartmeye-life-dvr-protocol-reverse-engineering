DVR_IP=192.168.1.10
DVR_USER=changeme
DVR_PASSWORD=changeme
DVR_CMD_PORT=6001
DVR_DATA_PORT=6002
DVR_STREAM=0
DVR_KEEPALIVE=1s
DVR_RECONNECT=3s
DVR_VERBOSE=0
DVR_LOG_JSON=0
# cam1->proto0, cam2->proto1, ...
DVR_PROTOCOL_OFFSET=-1
# optional explicit mapping user:proto (overrides offset), e.g. 1:0,2:1,3:2,4:3,5:4
DVR_CHANNEL_MAP=
# optional: enable bridge diagnostic log
DVR_DIAG_FILE=/config/diag_cam1.log
# optional: expose Prometheus metrics (set only on hub if desired), e.g. 127.0.0.1:9910
DVR_METRICS_ADDR=

# hub mode (single DVR session + local per-channel subscribers)
DVR_HUB_BIND=127.0.0.1
DVR_HUB_PORT_BASE=9100
# DVR supports up to 8 channels; default keeps only active channels in this setup.
DVR_HUB_CHANNELS=1,2,3,4,5
